# RunPod Service URLs (fallback when autoscaler disabled)
LID_SERVICE_URL=https://YOUR_POD1_ID-6001.proxy.runpod.net
INDIC_EN_SERVICE_URL=https://YOUR_POD2_ID-6002.proxy.runpod.net
EN_INDIC_SERVICE_URL=https://YOUR_POD3_ID-6003.proxy.runpod.net
SERVICE_PORT=6005

# Autoscaler
AUTOSCALER_ENABLED=true
RUNPOD_API_KEY=your_runpod_api_key

# Existing pod IDs
LID_INITIAL_POD_IDS=YOUR_POD1_ID
INDIC_EN_INITIAL_POD_IDS=YOUR_POD2_ID
EN_INDIC_INITIAL_POD_IDS=YOUR_POD3_ID

# Pool limits
LID_MIN_PODS=1
LID_MAX_PODS=5
INDIC_EN_MIN_PODS=1
INDIC_EN_MAX_PODS=10
EN_INDIC_MIN_PODS=1
EN_INDIC_MAX_PODS=10

# Scaling thresholds
SCALE_UP_RPS_THRESHOLD=50
SCALE_UP_LATENCY_MS=2000
SCALE_DOWN_RPS_THRESHOLD=5
SCALE_DOWN_IDLE_MINUTES=10
